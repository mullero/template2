# =============================================================================
# machote — ROOT ENVIRONMENT TEMPLATE (single source of truth)
# =============================================================================
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# `scripts/sync-config.sh` reads `.env` (+ `.env.${DEPLOYMENT_ENVIRONMENT}` +
# `.env.local`) and GENERATES backend/.env, frontend/.env.development and
# frontend/.env.production. Do not hand-edit the generated files.
#
# Priority (highest -> lowest):
#   runtime env  >  Secret Manager  >  .env.local  >  .env.{env}  >  .env  >  app defaults
#
# Placeholders written as CHANGE_ME are rejected by validate_config() in any
# non-development environment.
# =============================================================================

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
DEPLOYMENT_ENVIRONMENT=development          # development | testing | staging | production
PROJECT_NAME=machote
PRODUCT_NAME=machote
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR

# -----------------------------------------------------------------------------
# Database (Postgres) — pool sizing included
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=machote
POSTGRES_USER=machote
POSTGRES_PASSWORD=CHANGE_ME
# Full async URL is derived by the backend from the parts above, but may be
# overridden explicitly (e.g. Cloud SQL unix socket):
# DATABASE_URL=postgresql+asyncpg://machote:CHANGE_ME@postgres:5432/machote
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# -----------------------------------------------------------------------------
# Cloud / Storage (GCP)
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=CHANGE_ME
GCP_REGION=us-central1
GCS_BUCKET=CHANGE_ME
GOOGLE_APPLICATION_CREDENTIALS=/app/adc/credentials.json

# -----------------------------------------------------------------------------
# AI provider (Gemini / Vertex AI)
# -----------------------------------------------------------------------------
AI_ENABLED=true
AI_PROVIDER=vertex                         # vertex | gemini
GEMINI_API_KEY=CHANGE_ME
VERTEX_LOCATION=us-central1
AI_MODEL=gemini-1.5-flash

# -----------------------------------------------------------------------------
# Graph database (Neo4j) — SECONDARY, derived store; Postgres stays system of record
# -----------------------------------------------------------------------------
GRAPH_ENABLED=true
NEO4J_URI=bolt://neo4j:7687              # neo4j+s://<id>.databases.neo4j.io in cloud
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CHANGE_ME
NEO4J_DATABASE=neo4j
NEO4J_MAX_POOL_SIZE=50

# -----------------------------------------------------------------------------
# Auth / Firebase (Identity Platform)
# -----------------------------------------------------------------------------
AUTH_ENABLED=true                          # false = LOCAL DEV ONLY (stub superadmin)
FIREBASE_PROJECT_ID=CHANGE_ME
FIREBASE_AUTH_EMULATOR_HOST=               # e.g. firebase-emulator:9099 for local
# Frontend Firebase web config (VITE_ prefixed — embedded at build time):
VITE_FIREBASE_API_KEY=CHANGE_ME
VITE_FIREBASE_AUTH_DOMAIN=CHANGE_ME.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=CHANGE_ME
VITE_FIREBASE_STORAGE_BUCKET=CHANGE_ME.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=CHANGE_ME
VITE_FIREBASE_APP_ID=CHANGE_ME
VITE_FIREBASE_AUTH_EMULATOR_HOST=          # e.g. http://localhost:9099 for local

# -----------------------------------------------------------------------------
# API + security
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_VERSION=0.1.0
SECRET_KEY=CHANGE_ME
ENABLE_SWAGGER=true                        # force false in production
ENABLE_DETAILED_ERRORS=true                # force false in production
ENABLE_DEV_ROUTES=true                     # dev-only routers; false in production

# -----------------------------------------------------------------------------
# CORS (explicit — never "*" with credentials)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Requested-With

# -----------------------------------------------------------------------------
# Frontend flags (VITE_ prefixed)
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000/api
VITE_DISABLE_AUTH=false                    # true = dev bypass of route guards
VITE_ENABLE_ANALYTICS=false

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
FEATURE_PROJECTS=true
FEATURE_TASKS=true

# -----------------------------------------------------------------------------
# Resource limits
# -----------------------------------------------------------------------------
MAX_REQUEST_BODY_BYTES=10485760            # 10 MiB
REQUEST_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# Rate limiting (slowapi)
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute

# -----------------------------------------------------------------------------
# Bootstrap admin (first superadmin, dev/seed only)
# -----------------------------------------------------------------------------
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME
BOOTSTRAP_TENANT_ID=dev-tenant

# -----------------------------------------------------------------------------
# Sentry (optional)
# -----------------------------------------------------------------------------
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# OpenTelemetry (optional)
# -----------------------------------------------------------------------------
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=machote-backend

# -----------------------------------------------------------------------------
# Startup / migration safety (entrypoint.sh)
# -----------------------------------------------------------------------------
DRIFT_CHECK_ENABLED=true
RESET_DB_ON_STARTUP=false                  # DESTRUCTIVE — entrypoint refuses to boot if true
